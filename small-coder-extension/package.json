{
  "name": "small-coder-extension",
  "displayName": "Small Coder for Visual Studio Code",
  "description": "Un LLM personalizado local para tu VSCode",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./output/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "small-coder-extension.predict",
        "title": "SmallCoder: Predict from the cursor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "keywords": [],
  "authors": [
    "Antonio De León",
    "Juan José Lopera"
  ],
  "license": "ISC",
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}
